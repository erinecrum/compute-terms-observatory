# Secrets — never commit the API key. This line is here from the first commit.
.env

# Machine-local Claude Code settings (personal permission allowlist)
.claude/settings.local.json

# Python
.venv/
__pycache__/
*.pyc
*.egg-info/

# Generated site output is a build artifact, rebuilt from the corpus + dataset.
site/

# Data corpus (snapshots + extractions + dataset + change notes) lives in the
# PRIVATE repo compute-terms-observatory-data. Only the public freshness marker
# (data/last-checked.json) is committed here.
snapshots/
data/*
!data/last-checked.json

# macOS Finder metadata
.DS_Store
