# Secrets — never commit the API key. This line is here from the first commit.
.env

# Machine-local Claude Code settings (personal permission allowlist)
.claude/settings.local.json

# Python
.venv/
__pycache__/
*.pyc
*.egg-info/

# Generated site output is a build artifact, rebuilt from the corpus + dataset.
site/

# Data corpus lives in the PRIVATE repo compute-terms-observatory-data. New
# snapshots and dataset files are NOT committed to this public repo going forward.
# The already-committed snapshots/ + data/ remain as a frozen public baseline
# (git keeps tracking files added before this rule; only NEW files are ignored).
snapshots/
data/

# macOS Finder metadata
.DS_Store
